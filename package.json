{
    "name": "qml-debug",
    "publisher": "orcun-gokbulut",
    "displayName": "QML Debug",
    "description": "Visual Studio Code debugging support for Qt QML language",
    "version": "0.1.0",
    "icon": "qml-debug.png",
    "author": {
        "name": "Y. Orçun Gökbulut",
        "email": "orcun.gokbulut@gmail.com",
        "url": "https://www.github.com/orcun-gokbulut"
    },
    "homepage": "https://github.com/orcun-gokbulut/qml-debug",
    "bugs": {
        "url": "https://github.com/orcun-gokbulut/qml-debug/issues",
        "email": "orcun.gokbulut@gmail.com"
    },
    "repository": {
        "type": "git",
        "url": "https://www.github.com/orcun-gokbulut/qml-debug.git"
    },
    "license": "GPL-3.0",
    "categories": [
        "Debuggers"
    ],
    "keywords": [
        "QML",
        "Qt",
        "Debugger"
    ],
    "engines": {
        "node": ">=22.13.0 <23",
        "vscode": "^1.120.0"
    },
    "packageManager": "npm@10.9.2",
    "main": "dist/extension.js",
    "activationEvents": [
        "onDebugResolve:qml"
    ],
    "contributes": {
        "commands": [
            {
                "command": "qml-debug.version",
                "category": "QML Debug",
                "title": "Version Information",
                "icon": "$(law)"
            },
            {
                "command": "qml-debug.copyright",
                "category": "QML Debug",
                "title": "Copyright Information",
                "icon": "$(info)"
            },
            {
                "command": "qml-debug.enableFilterFunctions",
                "category": "QML Debug",
                "title": "Show Functions",
                "icon": "$(filter)"
            },
            {
                "command": "qml-debug.disableFilterFunctions",
                "category": "QML Debug",
                "title": "Hide Functions",
                "icon": "$(filter)"
            },
            {
                "command": "qml-debug.enableSortMembers",
                "category": "QML Debug",
                "title": "Disable Sort",
                "icon": "$(sort-precedence)"
            },
            {
                "command": "qml-debug.disableSortMembers",
                "category": "QML Debug",
                "title": "Enable Sort",
                "icon": "$(sort-precedence)"
            },
            {
                "command": "qml-debug.inspectCurrentQmlItem",
                "category": "QML Debug",
                "title": "Inspect Current QML Item",
                "icon": "$(target)"
            },
            {
                "command": "qml-debug.toggleInspector",
                "category": "QML Debug",
                "title": "Toggle Inspector Selection",
                "icon": "$(selection)"
            },
            {
                "command": "qml-debug.toggleInspectorAppOnTop",
                "category": "QML Debug",
                "title": "Toggle Inspector App On Top",
                "icon": "$(window)"
            },
            {
                "command": "qml-debug.startProfiler",
                "category": "QML Debug",
                "title": "Start QML Profiler Capture",
                "icon": "$(play)"
            },
            {
                "command": "qml-debug.stopProfiler",
                "category": "QML Debug",
                "title": "Stop QML Profiler Capture",
                "icon": "$(debug-stop)"
            },
            {
                "command": "qml-debug.clearProfiler",
                "category": "QML Debug",
                "title": "Clear QML Profiler Snapshot",
                "icon": "$(clear-all)"
            },
            {
                "command": "qml-debug.exportProfilerSnapshot",
                "category": "QML Debug",
                "title": "Export QML Profiler Snapshot",
                "icon": "$(export)"
            },
            {
                "command": "qml-debug.refreshRuntimeTools",
                "category": "QML Debug",
                "title": "Refresh Runtime Tools",
                "icon": "$(refresh)"
            },
            {
                "command": "qml-debug.automation.describe",
                "category": "QML Debug Automation",
                "title": "Describe Automation API"
            },
            {
                "command": "qml-debug.automation.sessions",
                "category": "QML Debug Automation",
                "title": "List Automation Sessions"
            },
            {
                "command": "qml-debug.automation.run",
                "category": "QML Debug Automation",
                "title": "Run Automation Action"
            }
        ],
        "configuration": [
            {
                "title": "QML Debug",
                "properties": {
                    "qml-debug.filterFunctions": {
                        "type": "boolean",
                        "default": true,
                        "description": "Hide member functions of object variables in Variables, Watches and Quick Watch views."
                    },
                    "qml-debug.sortMembers": {
                        "type": "boolean",
                        "default": true,
                        "description": "Sort members of object variables according to their names."
                    }
                }
            }
        ],
        "languages": [
            {
                "id": "qml",
                "aliases": [
                    "Qt QML"
                ],
                "extensions": [
                    ".qml"
                ]
            }
        ],
        "menus": {
            "debug/variables/context": [
                {
                    "command": "qml-debug.enableFilterFunctions",
                    "group": "options",
                    "when": "debugType == 'qml' && !qmldebug.filterFunctions"
                },
                {
                    "command": "qml-debug.disableFilterFunctions",
                    "group": "options",
                    "when": "debugType == 'qml' && qmldebug.filterFunctions"
                },
                {
                    "command": "qml-debug.enableSortMembers",
                    "group": "options",
                    "when": "debugType == 'qml' && !qmldebug.sortMembers"
                },
                {
                    "command": "qml-debug.disableSortMembers",
                    "group": "options",
                    "when": "debugType == 'qml' && qmldebug.sortMembers"
                }
            ],
            "view/title": [
                {
                    "command": "qml-debug.inspectCurrentQmlItem",
                    "group": "navigation",
                    "when": "view == qml-debug.inspector"
                },
                {
                    "command": "qml-debug.toggleInspector",
                    "group": "navigation",
                    "when": "view == qml-debug.inspector"
                },
                {
                    "command": "qml-debug.toggleInspectorAppOnTop",
                    "group": "navigation",
                    "when": "view == qml-debug.inspector"
                },
                {
                    "command": "qml-debug.startProfiler",
                    "group": "navigation",
                    "when": "view == qml-debug.profiler && qmldebug.profilerAvailable && !qmldebug.profilerRecording"
                },
                {
                    "command": "qml-debug.stopProfiler",
                    "group": "navigation",
                    "when": "view == qml-debug.profiler && qmldebug.profilerAvailable && qmldebug.profilerRecording"
                },
                {
                    "command": "qml-debug.clearProfiler",
                    "group": "navigation",
                    "when": "view == qml-debug.profiler && qmldebug.profilerAvailable"
                },
                {
                    "command": "qml-debug.exportProfilerSnapshot",
                    "group": "navigation",
                    "when": "view == qml-debug.profiler && qmldebug.profilerAvailable"
                },
                {
                    "command": "qml-debug.refreshRuntimeTools",
                    "group": "navigation",
                    "when": "view == qml-debug.inspector || view == qml-debug.profiler"
                }
            ]
        },
        "views": {
            "debug": [
                {
                    "id": "qml-debug.inspector",
                    "name": "QML Inspector",
                    "when": "debugType == qml"
                },
                {
                    "id": "qml-debug.profiler",
                    "name": "QML Profiler",
                    "when": "debugType == qml"
                }
            ]
        },
        "breakpoints": [
            {
                "language": "qml"
            }
        ],
        "debuggers": [
            {
                "type": "qml",
                "label": "QML Debugger",
                "program": "./out/debug-adapter.js",
                "runtime": "node",
                "configurationAttributes": {
                    "attach": {
                        "required": [
                            "host",
                            "port"
                        ],
                        "properties": {
                            "host": {
                                "type": "string",
                                "description": "Hostname (or ip address) of the target program's debug service.",
                                "default": "localhost"
                            },
                            "port": {
                                "type": "number",
                                "description": "Port of the target program's debug service."
                            },
                            "paths": {
                                "description": "List of qml source folders resource paths (qrc:/) to physical path mappings.",
                                "type": "object",
                                "patternProperties": {
                                    ".*": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    }
                                }
                            },
                            "trace": {
                                "type": "boolean",
                                "description": "Enable logging of the Debug Adapter Protocol.",
                                "default": true
                            }
                        }
                    },
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Path to the Qt/QML application executable."
                            },
                            "args": {
                                "type": "array",
                                "description": "Application arguments. The adapter appends -qmljsdebugger automatically.",
                                "items": {
                                    "type": "string"
                                },
                                "default": []
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory for the launched application."
                            },
                            "env": {
                                "type": "object",
                                "description": "Additional environment variables for the launched application.",
                                "additionalProperties": {
                                    "type": "string"
                                }
                            },
                            "host": {
                                "type": "string",
                                "description": "Hostname (or ip address) where the target program's debug service will listen.",
                                "default": "localhost"
                            },
                            "port": {
                                "type": "number",
                                "description": "Port where the target program's debug service will listen.",
                                "default": 12150
                            },
                            "paths": {
                                "description": "List of qml source folders resource paths (qrc:/) to physical path mappings.",
                                "type": "object",
                                "patternProperties": {
                                    ".*": {
                                        "type": [
                                            "string",
                                            "null"
                                        ]
                                    }
                                }
                            },
                            "services": {
                                "type": "array",
                                "description": "Qt QML debug services requested from -qmljsdebugger. Profiler capture requires CanvasFrameRate; EngineControl is optional coordination support.",
                                "items": {
                                    "type": "string"
                                },
                                "default": [
                                    "DebugMessages",
                                    "QmlDebugger",
                                    "V8Debugger",
                                    "QmlInspector"
                                ]
                            },
                            "block": {
                                "type": "boolean",
                                "description": "Add block to -qmljsdebugger so the QML runtime waits for the debugger before executing.",
                                "default": true
                            },
                            "trace": {
                                "type": "boolean",
                                "description": "Enable logging of the Debug Adapter Protocol.",
                                "default": true
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "qml",
                        "request": "attach",
                        "name": "Attach to QML Debugger",
                        "host": "localhost",
                        "port": 12150,
                        "paths": [],
                        "trace": false
                    },
                    {
                        "type": "qml",
                        "request": "launch",
                        "name": "Launch QML Application",
                        "program": "${workspaceFolder}/<your_qml_application>",
                        "args": [],
                        "host": "localhost",
                        "port": 12150,
                        "paths": {},
                        "block": true,
                        "trace": false
                    },
                    {
                        "type": "qml",
                        "request": "launch",
                        "name": "Launch QML with Inspector + Profiler",
                        "program": "${workspaceFolder}/<your_qml_application>",
                        "args": [],
                        "host": "localhost",
                        "port": 12150,
                        "paths": {},
                        "services": [
                            "DebugMessages",
                            "QmlDebugger",
                            "V8Debugger",
                            "QmlInspector",
                            "CanvasFrameRate",
                            "EngineControl"
                        ],
                        "block": true,
                        "trace": false
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "QML Debug: Attach",
                        "description": "A new configuration for 'debugging' QML based application. You can only attach to QML based application.",
                        "body": {
                            "name": "QML Debug: Attach",
                            "type": "qml",
                            "request": "attach",
                            "host": "localhost",
                            "port": 12150,
                            "paths": {
                                "qrc:/qml": "^\"\\${workspaceFolder}/<Folder that contain qml files>\""
                            }
                        }
                    },
                    {
                        "label": "QML Debug: Launch",
                        "description": "Launch a Qt/QML application and attach the QML debugger automatically.",
                        "body": {
                            "name": "QML Debug: Launch",
                            "type": "qml",
                            "request": "launch",
                            "program": "^\"\\${workspaceFolder}/<your_qml_application>\"",
                            "args": [],
                            "host": "localhost",
                            "port": 12150,
                            "paths": {
                                "qrc:/qml": "^\"\\${workspaceFolder}/qml\""
                            },
                            "block": true
                        }
                    },
                    {
                        "label": "QML Debug: Launch With Inspector + Profiler",
                        "description": "Launch a Qt/QML application with QmlInspector, CanvasFrameRate, and optional EngineControl coordination enabled.",
                        "body": {
                            "name": "QML Debug: Launch With Inspector + Profiler",
                            "type": "qml",
                            "request": "launch",
                            "program": "^\"\\${workspaceFolder}/<your_qml_application>\"",
                            "args": [],
                            "host": "localhost",
                            "port": 12150,
                            "paths": {
                                "qrc:/qml": "^\"\\${workspaceFolder}/qml\""
                            },
                            "services": [
                                "DebugMessages",
                                "QmlDebugger",
                                "V8Debugger",
                                "QmlInspector",
                                "CanvasFrameRate",
                                "EngineControl"
                            ],
                            "block": true
                        }
                    }
                ]
            }
        ],
        "snippets": [
            {
                "language": "jsonc",
                "path": "./snippets/qml-debug.code-snippets"
            }
        ]
    },
    "_moduleAliases": {
        "@qml-debug": "./src",
        "@qml-debug-root": "."
    },
    "scripts": {
        "toolchain:node": "./scripts/with-node22.sh node -v",
        "bootstrap": "npm install",
        "bootstrap:portable": "./scripts/with-node22.sh npm install",
        "bootstrap-prod": "npm install --omit=dev",
        "bootstrap-prod:portable": "./scripts/with-node22.sh npm install --omit=dev",
        "compile": "tsc -p ./",
        "lint": "eslint src",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
        "esbuild-base": "esbuild ./src/extension/extension.ts --bundle --tsconfig=./tsconfig.json --external:vscode --format=cjs --platform=node --sourcemap --outfile=dist/extension.js",
        "watch": "npm run -S esbuild-base -- --sources-content=false --watch",
        "build": "npm run -S esbuild-base -- --sources-content=false",
        "package": "vsce package",
        "publish": "vsce publish",
        "publish-pre-release": "vsce publish --pre-release",
        "vscode:prepublish": "rm -rf dist && npm run -S esbuild-base -- --minify",
        "fixture:configure": "cmake -S test/qt-fixture -B test/qt-fixture/build",
        "fixture:build": "cmake --build test/qt-fixture/build",
        "test:qt-ci": "npm run fixture:configure && npm run fixture:build && npm run test:qt-integration",
        "test:compile": "tsc -p tsconfig.test.json",
        "test:unit": "npm run test:compile && mocha --require ./out-test/test/bootstrap.js \"out-test/test/**/*.test.js\"",
        "test:qt-integration": "npm run test:compile && mocha --require ./out-test/test/bootstrap.js out-test/test/qt-integration.test.js",
        "test:coverage": "nyc --reporter=text --reporter=html npm run test:unit",
        "ci": "npm run typecheck && npm run typecheck:test && npm run test:unit && npm run build",
        "ci:portable": "./scripts/with-node22.sh npm run ci",
        "test": "npm run typecheck && npm run test:unit",
        "clean": "rm -rfv ./out/* ./out-test/* ./dist/*",
        "dist-clean": "rm -rfv ./node_modules ./out ./out-test ./dist"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "22.x",
        "@types/vscode": "^1.120.0",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "@vscode/debugadapter-testsupport": "^1.68.0",
        "@vscode/test-electron": "^2.5.2",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.0",
        "eslint": "^10.4.0",
        "globals": "^16.5.0",
        "mocha": "^11.7.5",
        "nyc": "^18.0.0",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "@vscode/debugadapter": "^1.68.0",
        "@vscode/debugprotocol": "^1.68.0",
        "buffer-hex": "^1.0.0",
        "colors": "^1.4.0",
        "module-alias": "^2.2.2",
        "promise-socket": "^8.0.0",
        "source-map-support": "^0.5.21"
    }
}
